# Copy this file to .env and fill in real values after deploying server/
# (see server/README.md). Leaving these unset is fine — the app runs
# standalone without the messaging/notifications features.

VITE_RELAY_URL=wss://your-app-name.fly.dev
VITE_RELAY_TOKEN=your-relay-token

# Push notifications (message received / update available) need this too --
# the VAPID *public* key only, safe to expose in the client bundle. Generate
# a keypair with `npx web-push generate-vapid-keys` and set both halves on
# the server as VAPID_PUBLIC_KEY/VAPID_PRIVATE_KEY (see server/README.md).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
